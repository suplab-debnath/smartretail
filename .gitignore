# ── Java / Maven ──────────────────────────────────────────────────────────────
*.class
*.jar
*.war
target/
# openapi-generator output (regenerated on every build)
**/target/generated-sources/openapi/

# ── TypeScript / React MFEs ───────────────────────────────────────────────────
node_modules/
dist/
coverage/
# The Maven aggregate-report module is source, not generated output
!services/coverage/
# Generated API client (regenerated from openapi yaml)
mfe/shared/api-client/src/generated/
# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── AWS CDK ───────────────────────────────────────────────────────────────────
# cdk-min: demo/dev stack (SQS-only, default VPC) — the stack we run
infra/cdk-min/cdk.out/
infra/cdk-min/**/*.js
infra/cdk-min/**/*.d.ts
!infra/cdk-min/jest.config.js

# cdk-prod: production stack (Kinesis) — not wired into Makefile; manual deploys only
infra/cdk-prod/cdk.out/
infra/cdk-prod/**/*.js
infra/cdk-prod/**/*.d.ts
!infra/cdk-prod/jest.config.js

# cdk-dev: dev stack (Kinesis, default VPC)
infra/cdk-dev/cdk.out/
infra/cdk-dev/**/*.js
infra/cdk-dev/**/*.d.ts
!infra/cdk-dev/jest.config.js

# ── Python scripts ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
# AWS credentials are never committed
.aws/

# ── IDEs & editors ────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.Spotlight-V100/
.Trashes/
Thumbs.db

# ── Logs & temporary files ────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/

# -- Claude
.claude/worktrees/*



