# ── Java / Maven ──────────────────────────────────────────────────────────────
*.class
*.jar
*.war
target/
# openapi-generator output (regenerated on every build)
**/target/generated-sources/openapi/

# ── TypeScript / React MFEs ───────────────────────────────────────────────────
node_modules/
dist/
coverage/
# The Maven aggregate-report module is source, not generated output
!services/coverage/
# Generated API client (regenerated from openapi yaml)
mfe/shared/api-client/src/generated/
# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── AWS CDK ───────────────────────────────────────────────────────────────────
infra/cdk/cdk.out/
# Compiled TypeScript output (CDK is run via ts-node; these are not committed)
infra/cdk/**/*.js
infra/cdk/**/*.d.ts
!infra/cdk/jest.config.js

# ── Python scripts ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
# AWS credentials are never committed
.aws/

# ── IDEs & editors ────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.Spotlight-V100/
.Trashes/
Thumbs.db

# ── Logs & temporary files ────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/

# -- Claude
.claude/worktrees/*



