root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.java]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2
max_line_length = 120

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.sql]
indent_style = space
indent_size = 2
max_line_length = 100

[*.xml]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 2
