{
  "model": "claude-sonnet-4-6",
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git stash list*)",
      "Bash(git remote*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -b*)",
      "Bash(git switch -c*)",
      "Bash(git switch *)",
      "Bash(git push origin *)",
      "Bash(ls*)",
      "Bash(find . *)",
      "Bash(find src *)",
      "Bash(find backend *)",
      "Bash(find mfe *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(java --version)",
      "Bash(mvn --version)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(docker --version)",
      "Bash(mvn clean*)",
      "Bash(mvn compile*)",
      "Bash(mvn test*)",
      "Bash(mvn verify*)",
      "Bash(mvn generate-sources*)",
      "Bash(mvn package*)",
      "Bash(mvn spring-boot:run*)",
      "Bash(mvn dependency:tree*)",
      "Bash(mvn help:effective-pom*)",
      "Bash(mvn flyway:info*)",
      "Bash(mvn flyway:validate*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm run type-check*)",
      "Bash(npm run test*)",
      "Bash(npm run generate-api*)",
      "Bash(npm run dev*)",
      "Bash(docker-compose up*)",
      "Bash(docker-compose down*)",
      "Bash(docker-compose ps*)",
      "Bash(docker-compose logs*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(make local-up*)",
      "Bash(make local-down*)",
      "Bash(make local-migrate*)",
      "Bash(make local-seed*)",
      "Bash(make test-flow*)",
      "Bash(make build-all*)",
      "Bash(make build-service*)",
      "Bash(make local-sis*)",
      "Bash(make local-ims*)",
      "Bash(make local-re*)",
      "Bash(make local-ars*)",
      "Bash(make local-dfs*)",
      "Bash(make local-sup*)",
      "Bash(make local-pps*)",
      "Bash(make coverage*)",
      "Bash(aws ecs describe*)",
      "Bash(aws ecs list*)",
      "Bash(aws sqs get-queue-attributes*)",
      "Bash(aws sqs list-queues*)",
      "Bash(aws logs filter-log-events*)",
      "Bash(aws logs describe-log-groups*)",
      "Bash(aws codepipeline get-pipeline-state*)",
      "Bash(aws codepipeline list-pipeline-executions*)",
      "Bash(aws codepipeline get-pipeline-execution*)",
      "Bash(aws codebuild batch-get-builds*)",
      "Bash(aws cloudformation describe-stacks*)",
      "Bash(aws rds describe-db-instances*)",
      "Bash(aws secretsmanager describe-secret*)",
      "Bash(awslocal*)",
      "Bash(curl -s http://localhost*)",
      "Read(*)"
    ],
    "deny": [
      "Bash(git push*--force*)",
      "Bash(git push*-f *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)",
      "Bash(git restore .)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*drop database*)",
      "Bash(*DROP SCHEMA*)",
      "Bash(*drop schema*)",
      "Bash(*DROP TABLE*)",
      "Bash(*drop table*)",
      "Bash(psql*DROP*)",
      "Bash(psql*drop*)",
      "Bash(cdk destroy*)",
      "Bash(*destroy-infra*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-guard.sh"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/on-stop.sh" }
        ]
      }
    ]
  },

  "env": {
    "SPRING_PROFILES_ACTIVE": "local",
    "SMARTRETAIL_ENV": "local",
    "AWS_ENDPOINT_URL": "http://localhost:4566",
    "AWS_DEFAULT_REGION": "us-east-1",
    "AWS_ACCESS_KEY_ID": "test",
    "AWS_SECRET_ACCESS_KEY": "test"
  }
}
